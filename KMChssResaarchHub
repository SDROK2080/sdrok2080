.footer-col h4 { font-size: 0.85rem; font-weight: 600; color: var(--white); margin-bottom: 1.2rem; letter-spacing: 0.04em; }
.footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.55rem; }
.footer-col ul li a { font-size: 0.82rem; color: rgba(255,255,255,0.48); transition: color var(--transition); }
