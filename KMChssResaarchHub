<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KMC Humanities & Social Sciences | Taulihawa, Kapilvastu</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════
   DESIGN TOKENS
   Palette: Deep Himalayan Blue + Saffron Gold + Crimson
   Signature: Diagonal bilingual wordmark band in hero
═══════════════════════════════════════════════════ */
:root {
  --blue-deep:  #0B1F3A;
  --blue-mid:   #163A5F;
  --blue-light: #1E5080;
  --saffron:    #D4821A;
  --gold:       #F0A83C;
  --gold-pale:  #FDF0D5;
  --crimson:    #C0392B;
  --sage:       #2E6B4F;
  --white:      #FFFFFF;
  --off-white:  #F7F5F2;
  --ink:        #1A1A2A;
  --muted:      #5A6272;
  --border:     #DDD9D0;
  --card-bg:    #FDFCFA;

  --font-serif: 'DM Serif Display', Georgia, serif;
  --font-sans:  'DM Sans', system-ui, sans-serif;
  --font-mono:  'Space Mono', monospace;

  --radius:     10px;
  --radius-lg:  18px;
  --shadow-sm:  0 2px 12px rgba(11,31,58,0.08);
  --shadow-md:  0 6px 28px rgba(11,31,58,0.13);
  --shadow-lg:  0 16px 56px rgba(11,31,58,0.20);
  --transition: 0.28s cubic-bezier(0.4,0,0.2,1);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; font-size: 16px; }
body { font-family: var(--font-sans); background: var(--off-white); color: var(--ink); line-height: 1.7; overflow-x: hidden; }
a { color: inherit; text-decoration: none; }
img { display: block; max-width: 100%; }

/* ─── SCROLLBAR ─────── */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--blue-deep); }
::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 3px; }

/* ═══════════════════════════════════════════════════
   NAVIGATION
═══════════════════════════════════════════════════ */
#nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  background: rgba(11,31,58,0.96);
  backdrop-filter: blur(16px) saturate(180%);
  border-bottom: 1px solid rgba(240,168,60,0.18);
  transition: box-shadow var(--transition);
}
#nav.scrolled { box-shadow: 0 4px 32px rgba(0,0,0,0.35); }
.nav-wrap {
  max-width: 1280px; margin: 0 auto; padding: 0 2rem;
  display: flex; align-items: center; justify-content: space-between;
  height: 70px;
}
.nav-logo { display: flex; align-items: center; gap: 0.85rem; }
.nav-crest {
  width: 44px; height: 44px; border-radius: 50%;
  background: conic-gradient(from 0deg, var(--gold) 0%, var(--saffron) 50%, var(--gold) 100%);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-serif); font-size: 1rem; color: var(--blue-deep);
  font-weight: 700; letter-spacing: -0.5px; flex-shrink: 0;
  box-shadow: 0 0 0 3px rgba(240,168,60,0.25);
}
.nav-title { line-height: 1.25; }
.nav-title .t1 { font-family: var(--font-serif); font-size: 1rem; color: var(--white); display: block; }
.nav-title .t2 { font-size: 0.7rem; color: var(--gold); letter-spacing: 0.1em; text-transform: uppercase; display: block; }
.nav-menu { display: flex; align-items: center; gap: 0.15rem; list-style: none; }
.nav-menu a {
  padding: 0.4rem 0.9rem; border-radius: var(--radius);
  font-size: 0.83rem; font-weight: 500; color: rgba(255,255,255,0.72);
  transition: color var(--transition), background var(--transition);
}
.nav-menu a:hover { color: var(--white); background: rgba(240,168,60,0.14); }
.nav-menu .nav-highlight a {
  background: var(--saffron); color: var(--white);
  border-radius: 24px; padding: 0.42rem 1.15rem;
  font-weight: 600;
}
.nav-menu .nav-highlight a:hover { background: var(--gold); }
.nav-hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; }
.nav-hamburger span { display: block; width: 24px; height: 2px; background: var(--white); border-radius: 2px; transition: var(--transition); }

/* ═══════════════════════════════════════════════════
   HERO  — signature: tilted Nepali/English band
═══════════════════════════════════════════════════ */
.hero {
  min-height: 100vh; position: relative; overflow: hidden;
  background: var(--blue-deep);
  display: flex; align-items: center;
}

/* Abstract geometric backdrop */
.hero-backdrop {
  position: absolute; inset: 0; pointer-events: none;
}
.hero-backdrop svg { width: 100%; height: 100%; opacity: 0.06; }

/* Signature diagonal band */
.hero-band {
  position: absolute; left: -4%; right: -4%; top: 50%;
  transform: translateY(-50%) rotate(-4deg);
  background: linear-gradient(90deg, rgba(212,130,26,0.08), rgba(240,168,60,0.05), rgba(212,130,26,0.08));
  border-top: 1px solid rgba(240,168,60,0.15);
  border-bottom: 1px solid rgba(240,168,60,0.15);
  padding: 0.6rem 0;
  white-space: nowrap; overflow: hidden;
  font-family: var(--font-mono); font-size: 0.75rem;
  color: rgba(240,168,60,0.3); letter-spacing: 0.15em;
  pointer-events: none;
}
.hero-band-inner { display: inline-block; animation: marquee 32s linear infinite; }
@keyframes marquee {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

.hero-inner {
  position: relative; z-index: 2;
  max-width: 1280px; margin: 0 auto;
  padding: 8rem 2rem 5rem;
  display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;
}
.hero-left {}
.hero-kicker {
  display: inline-flex; align-items: center; gap: 0.6rem;
  font-family: var(--font-mono); font-size: 0.72rem;
  color: var(--gold); letter-spacing: 0.2em; text-transform: uppercase;
  margin-bottom: 1.4rem;
}
.hero-kicker::before { content: ''; width: 32px; height: 1.5px; background: var(--gold); display: block; }
.hero h1 {
  font-family: var(--font-serif);
  font-size: clamp(2.6rem, 4.5vw, 4rem);
  line-height: 1.1; color: var(--white);
  margin-bottom: 1.5rem;
}
.hero h1 span { color: var(--gold); font-style: italic; }
.hero-desc {
  font-size: 1.05rem; color: rgba(255,255,255,0.62);
  max-width: 490px; line-height: 1.8; margin-bottom: 2.5rem;
}
.hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; }

.btn {
  display: inline-flex; align-items: center; gap: 0.5rem;
  padding: 0.82rem 1.9rem; border-radius: 32px;
  font-weight: 600; font-size: 0.9rem; border: none; cursor: pointer;
  transition: transform var(--transition), box-shadow var(--transition), opacity var(--transition);
}
.btn:hover { transform: translateY(-2px); }
.btn-gold { background: var(--gold); color: var(--blue-deep); box-shadow: 0 4px 20px rgba(240,168,60,0.40); }
.btn-gold:hover { box-shadow: 0 8px 32px rgba(240,168,60,0.55); }
.btn-ghost { background: transparent; color: var(--white); border: 1.5px solid rgba(255,255,255,0.28); }
.btn-ghost:hover { border-color: var(--gold); color: var(--gold); }

/* Hero right — floating info cards */
.hero-right { display: flex; flex-direction: column; gap: 1.1rem; }
.hero-card {
  background: rgba(255,255,255,0.045);
  border: 1px solid rgba(255,255,255,0.09);
  border-left: 3px solid var(--gold);
  border-radius: var(--radius);
  padding: 1.2rem 1.4rem;
  display: flex; align-items: flex-start; gap: 1rem;
  transition: background var(--transition), border-color var(--transition);
}
.hero-card:hover { background: rgba(240,168,60,0.06); border-color: rgba(240,168,60,0.4); }
.hero-card.red-accent { border-left-color: var(--crimson); }
.hero-card.sage-accent { border-left-color: var(--sage); }
.hc-icon { font-size: 1.6rem; flex-shrink: 0; line-height: 1; }
.hc-body h4 { font-size: 0.92rem; font-weight: 600; color: var(--white); margin-bottom: 0.25rem; }
.hc-body p { font-size: 0.8rem; color: rgba(255,255,255,0.5); line-height: 1.55; }

/* scroll indicator */
.hero-scroll {
  position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
  color: rgba(255,255,255,0.3); font-size: 0.68rem; letter-spacing: 0.15em; text-transform: uppercase;
}
.hero-scroll-line {
  width: 1px; height: 36px; background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent);
  animation: scrollLine 1.8s ease-in-out infinite;
}
@keyframes scrollLine { 0%,100%{opacity:0.3; transform:scaleY(1)} 50%{opacity:0.8; transform:scaleY(1.15)} }

/* ═══════════════════════════════════════════════════
   GLOBAL SECTION HELPERS
═══════════════════════════════════════════════════ */
.sec { padding: 6rem 0; }
.sec-dark { background: var(--blue-deep); }
.sec-mid  { background: var(--blue-mid); }
.sec-light { background: var(--off-white); }
.sec-white { background: var(--white); }
.wrap { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }

.sec-tag {
  font-family: var(--font-mono); font-size: 0.72rem;
  letter-spacing: 0.2em; text-transform: uppercase; color: var(--saffron);
  margin-bottom: 0.65rem; display: block;
}
.sec-tag.light { color: var(--gold); }
.sec-h {
  font-family: var(--font-serif); font-size: clamp(1.9rem, 3vw, 2.7rem);
  font-weight: 400; line-height: 1.2; color: var(--ink); margin-bottom: 0.85rem;
}
.sec-h.on-dark { color: var(--white); }
.sec-lead { font-size: 1rem; color: var(--muted); max-width: 580px; line-height: 1.8; margin-bottom: 0; }
.sec-lead.on-dark { color: rgba(255,255,255,0.58); }
.rule {
  width: 52px; height: 3px; margin: 1.2rem 0 2.8rem;
  background: linear-gradient(90deg, var(--gold), var(--saffron));
  border-radius: 2px;
}
.rule.centered { margin-left: auto; margin-right: auto; }

/* grid helpers */
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
.grid-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.75rem; }
.grid-4 { display: grid; grid-template-columns: repeat(4,1fr); gap: 1.5rem; }
.grid-auto { display: grid; grid-template-columns: repeat(auto-fill,minmax(280px,1fr)); gap: 1.5rem; }

/* ═══════════════════════════════════════════════════
   ABOUT / INTRODUCTION
═══════════════════════════════════════════════════ */
.about-layout { display: grid; grid-template-columns: 5fr 6fr; gap: 5rem; align-items: start; }
.about-visual { position: relative; }
.campus-card {
  background: linear-gradient(135deg, var(--blue-mid), var(--blue-deep));
  border-radius: var(--radius-lg); overflow: hidden;
  aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center;
  position: relative;
  box-shadow: var(--shadow-lg);
}
.campus-card-bg {
  position: absolute; inset: 0; opacity: 0.06;
  background-image: repeating-linear-gradient(45deg, var(--gold) 0, var(--gold) 1px, transparent 0, transparent 50%);
  background-size: 16px 16px;
}
.campus-card-inner { text-align: center; position: relative; z-index: 1; padding: 2rem; }
.campus-card-inner .icon { font-size: 4rem; margin-bottom: 0.85rem; }
.campus-card-inner h3 { font-family: var(--font-serif); font-size: 1.5rem; color: var(--gold); margin-bottom: 0.4rem; }
.campus-card-inner p { font-size: 0.85rem; color: rgba(255,255,255,0.55); line-height: 1.55; }
.about-float {
  position: absolute; bottom: -1.4rem; right: 1.5rem;
  background: var(--white); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 1rem 1.25rem;
  box-shadow: var(--shadow-md); display: flex; align-items: center; gap: 0.85rem;
}
.af-icon { width: 40px; height: 40px; background: linear-gradient(135deg,var(--gold),var(--saffron)); border-radius: 8px; display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0; }
.af-text strong { display: block; font-size: 0.88rem; color: var(--ink); font-weight: 600; }
.af-text span { font-size: 0.76rem; color: var(--muted); }

.about-text { padding-top: 0.5rem; }
.about-text p { color: var(--muted); margin-bottom: 1.15rem; font-size: 0.97rem; line-height: 1.85; }
.about-pills { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 2rem; }
.pill {
  padding: 0.38rem 0.9rem; border-radius: 20px; font-size: 0.78rem; font-weight: 500;
  background: rgba(46,107,79,0.1); color: var(--sage);
  border: 1px solid rgba(46,107,79,0.2);
}

/* ═══════════════════════════════════════════════════
   VISION / MISSION / GOAL TRIPTYCH
═══════════════════════════════════════════════════ */
.vmg-section {
  background: linear-gradient(135deg, var(--blue-mid) 0%, var(--blue-deep) 100%);
  padding: 5.5rem 0; position: relative; overflow: hidden;
}
.vmg-section::before {
  content: '';
  position: absolute; top: -60px; right: -60px;
  width: 360px; height: 360px;
  background: radial-gradient(circle, rgba(240,168,60,0.08), transparent 70%);
  pointer-events: none;
}
.vmg-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 0; }
.vmg-card {
  padding: 2.5rem 2.5rem;
  border-right: 1px solid rgba(255,255,255,0.08);
  transition: background var(--transition);
}
.vmg-card:last-child { border-right: none; }
.vmg-card:hover { background: rgba(255,255,255,0.03); }
.vmg-tag {
  font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--gold); margin-bottom: 0.85rem; display: block;
}
.vmg-card h3 {
  font-family: var(--font-serif); font-size: 1.35rem; font-style: italic;
  color: var(--white); margin-bottom: 0.85rem;
}
.vmg-card p { font-size: 0.88rem; color: rgba(255,255,255,0.56); line-height: 1.78; }

/* ═══════════════════════════════════════════════════
   PROGRAMS
═══════════════════════════════════════════════════ */
.prog-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(260px,1fr)); gap: 1.25rem; margin-top: 3rem; }
.prog-card {
  background: var(--card-bg); border: 1px solid var(--border);
  border-radius: var(--radius-lg); padding: 1.75rem;
  position: relative; overflow: hidden;
  transition: transform var(--transition), box-shadow var(--transition);
}
.prog-card::after {
  content: '';
  position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, var(--gold), var(--saffron));
  transform: scaleX(0); transform-origin: left; transition: transform 0.35s;
}
.prog-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-lg); }
.prog-card:hover::after { transform: scaleX(1); }
.prog-icon { font-size: 2.1rem; margin-bottom: 1rem; }
.prog-card h3 { font-family: var(--font-serif); font-size: 1.05rem; color: var(--ink); margin-bottom: 0.55rem; }
.prog-card p { font-size: 0.84rem; color: var(--muted); line-height: 1.65; }
.prog-badge {
  display: inline-block; margin-top: 1.1rem;
  padding: 0.22rem 0.7rem; border-radius: 12px;
  font-size: 0.7rem; font-weight: 600; letter-spacing: 0.05em;
  text-transform: uppercase; background: var(--gold-pale); color: var(--saffron);
}

/* ═══════════════════════════════════════════════════
   ACADEMIC PILLARS — TAB + ACCORDION HYBRID
═══════════════════════════════════════════════════ */
.pillars-layout { display: grid; grid-template-columns: 260px 1fr; gap: 2.5rem; margin-top: 3rem; align-items: start; }
.pillars-sidebar { position: sticky; top: 88px; }
.pillar-tab {
  display: flex; align-items: center; gap: 0.85rem;
  padding: 0.9rem 1rem; border-radius: var(--radius);
  cursor: pointer; transition: background var(--transition), color var(--transition);
  border: 1px solid transparent; margin-bottom: 0.4rem;
}
.pillar-tab:hover { background: rgba(212,130,26,0.06); }
.pillar-tab.active { background: var(--gold-pale); border-color: rgba(212,130,26,0.25); }
.pt-num { font-family: var(--font-mono); font-size: 0.65rem; color: var(--gold); font-weight: 700; width: 20px; flex-shrink: 0; }
.pt-icon { font-size: 1.1rem; flex-shrink: 0; }
.pt-label { font-size: 0.83rem; font-weight: 500; color: var(--ink); line-height: 1.35; }
.pillar-tab.active .pt-label { color: var(--saffron); font-weight: 600; }

.pillar-content { display: none; }
.pillar-content.active { display: block; animation: fadeSlide 0.3s ease; }
@keyframes fadeSlide { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
.pc-header {
  display: flex; align-items: center; gap: 1rem;
  background: linear-gradient(135deg, var(--blue-deep), var(--blue-mid));
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding: 1.75rem 2rem;
}
.pc-header .big-icon { font-size: 2.5rem; }
.pc-header h3 { font-family: var(--font-serif); font-size: 1.4rem; color: var(--white); margin-bottom: 0.25rem; }
.pc-header p { font-size: 0.83rem; color: rgba(255,255,255,0.55); }
.pc-body {
  background: var(--card-bg); border: 1px solid var(--border);
  border-top: none; border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  padding: 2rem;
}
.pc-intro { font-size: 0.93rem; color: var(--muted); line-height: 1.82; margin-bottom: 1.75rem; }
.pc-points { display: grid; grid-template-columns: 1fr 1fr; gap: 0.7rem; }
.pc-point {
  display: flex; align-items: flex-start; gap: 0.6rem;
  font-size: 0.85rem; color: var(--ink); line-height: 1.5;
}
.pc-point-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: var(--gold); flex-shrink: 0; margin-top: 0.44rem;
}

/* ═══════════════════════════════════════════════════
   RESEARCH
═══════════════════════════════════════════════════ */
.research-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; margin-top: 3rem; }
.res-cards { display: flex; flex-direction: column; gap: 1.1rem; }
.res-card {
  background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.09);
  border-radius: var(--radius); padding: 1.35rem 1.5rem;
  transition: background var(--transition), border-color var(--transition);
}
.res-card:hover { background: rgba(240,168,60,0.07); border-color: rgba(240,168,60,0.28); }
.res-card h4 { font-size: 0.93rem; font-weight: 600; color: var(--gold); margin-bottom: 0.45rem; display:flex;align-items:center;gap:0.55rem; }
.res-card p { font-size: 0.84rem; color: rgba(255,255,255,0.52); line-height: 1.68; }

.research-areas { display: grid; grid-template-columns: 1fr 1fr; gap: 0.9rem; }
.ra-tile {
  background: rgba(255,255,255,0.035); border: 1px solid rgba(255,255,255,0.08);
  border-radius: var(--radius); padding: 1.25rem; text-align: center;
  transition: all var(--transition); cursor: default;
}
.ra-tile:hover { background: rgba(240,168,60,0.09); border-color: rgba(240,168,60,0.28); transform: translateY(-2px); }
.ra-tile .rt-icon { font-size: 1.85rem; margin-bottom: 0.55rem; }
.ra-tile h5 { font-size: 0.83rem; font-weight: 600; color: var(--white); margin-bottom: 0.25rem; }
.ra-tile p { font-size: 0.74rem; color: rgba(255,255,255,0.42); }

/* ═══════════════════════════════════════════════════
   COMMUNITY ENGAGEMENT
═══════════════════════════════════════════════════ */
.comm-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; margin-top: 3rem; }
.comm-card {
  background: var(--white); border: 1px solid var(--border);
  border-radius: var(--radius-lg); padding: 2rem 1.75rem;
  text-align: center; transition: all var(--transition);
}
.comm-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-5px); }
.comm-card .cc-icon { font-size: 2.4rem; margin-bottom: 1rem; }
.comm-card h3 { font-family: var(--font-serif); font-size: 1.05rem; color: var(--ink); margin-bottom: 0.7rem; }
.comm-card p { font-size: 0.85rem; color: var(--muted); line-height: 1.72; }

/* ═══════════════════════════════════════════════════
   DIGITAL HUB / AI TOOLS
═══════════════════════════════════════════════════ */
.dh-section { background: var(--blue-deep); position: relative; overflow: hidden; }
.dh-section::after {
  content: '';
  position: absolute; bottom: -80px; left: 50%; transform: translateX(-50%);
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(192,57,43,0.08), transparent 70%);
  pointer-events: none;
}
.tools-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(230px,1fr)); gap: 1.2rem; margin-top: 3rem; }
.tool-card {
  background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
  border-radius: var(--radius-lg); padding: 1.65rem;
  position: relative; overflow: hidden;
  transition: all var(--transition); cursor: pointer;
}
.tool-card::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(circle at 50% 0%, rgba(240,168,60,0.06), transparent 70%);
  opacity: 0; transition: opacity var(--transition);
}
.tool-card:hover { transform: translateY(-3px); border-color: rgba(240,168,60,0.3); }
.tool-card:hover::before { opacity: 1; }
