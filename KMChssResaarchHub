  width: 180px; height: 180px; border-radius: 50%; margin: 0 auto 1.5rem;
  background: conic-gradient(from 0deg, var(--gold), var(--saffron), var(--crimson), var(--blue-light), var(--gold));
  padding: 4px; box-shadow: 0 0 40px rgba(240,168,60,0.25);
}
.portrait-inner {
  width: 100%; height: 100%; border-radius: 50%;
