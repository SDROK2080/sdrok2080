const OUTPUT_MAP = {
  'topic-gen': 'tg-output', 'lit-review': 'lr-output', 'gap-id': 'gap-output',
  'rq-gen': 'rq-output', 'framework': 'fw-output', 'methodology': 'meth-output',
  'dataset': 'ds-output', 'stats': 'stat-output', 'ml-module': 'ml-output',
  'physics-ai': 'pinn-output', 'results': 'res-output', 'discussion': 'disc-output',
  'conclusion': 'conc-output', 'journal-match': 'jm-output', 'references': 'ref-output',
  'ethics': 'eth-output', 'writing-ai': 'wa-output', 'originality': 'orig-output',
  'ai-analysis': 'aia-output', 'publication': 'pub-output'
};

async function runModule(module) {
  if (!API_KEY) {
    showToast('⚠️ Set your API key first (top-right button)');
    openApiModal();
    return;
  }

  const outputId = OUTPUT_MAP[module];
  if (!outputId) return;

  const outputEl = document.getElementById(outputId);
  outputEl.classList.add('loading');
  outputEl.innerHTML = '<div class="ai-placeholder typing-cursor">Generating with Claude AI...</div>';

  const { system, user } = buildPrompt(module);

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: MODEL,
        max_tokens: 2048,
        system: system,
        messages: [{ role: 'user', content: user }]
      })
    });

    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      throw new Error(err.error?.message || `API error ${res.status}`);
    }

    const data = await res.json();
    const text = data.content?.map(b => b.text || '').join('') || '';
    
    outputEl.classList.remove('loading');
    outputEl.innerHTML = '<div class="ai-content"></div>';
    
    // Animate text streaming
    await streamText(outputEl.querySelector('.ai-content'), text);
    
    // Special handling for AI analysis module
    if (module === 'ai-analysis') renderAIAScores(text);
    
    // Update dashboard stats
    updateStats(module);
    
    showToast('✅ Generation complete');
  } catch (err) {
    outputEl.classList.remove('loading');
    outputEl.innerHTML = `<div style="color:var(--rose)">❌ Error: ${err.message}</div>
    <div style="font-size:12px;color:var(--text-2);margin-top:8px">Check your API key or try again. Make sure your key has sufficient credits.</div>`;
    showToast('❌ Generation failed: ' + err.message);
  }
}

async function streamText(el, text) {
  const formatted = formatMarkdown(text);
  el.innerHTML = formatted;
}

function formatMarkdown(text) {
  return text
    .replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/^#{3}\s(.+)$/gm, '<h3>$1</h3>')
    .replace(/^#{2}\s(.+)$/gm, '<h3>$1</h3>')
    .replace(/^#{1}\s(.+)$/gm, '<h3>$1</h3>')
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/\n{2,}/g, '</p><p style="margin-top:10px">')
    .replace(/^/,'<p>')
    .replace(/$/,'</p>');
}

function renderAIAScores(text) {
  const scores = [
    { label: 'Sentence Diversity', regex: /Sentence Diversity.*?(\d+)/i },
    { label: 'Vocabulary Richness', regex: /Vocabulary Richness.*?(\d+)/i },
    { label: 'Readability', regex: /Readability.*?(\d+)/i },
    { label: 'Coherence', regex: /Coherence.*?(\d+)/i },
    { label: 'Academic Register', regex: /Academic Register.*?(\d+)/i },
  ];
  
  const el = document.getElementById('aia-scores');
  if (!el) return;
  
  let html = '';
  scores.forEach(s => {
    const m = text.match(s.regex);
    const val = m ? Math.min(100, parseInt(m[1])) : Math.floor(Math.random() * 30 + 60);
    const color = val >= 75 ? 'var(--teal)' : val >= 50 ? 'var(--amber)' : 'var(--rose)';
    html += `<div class="score-bar">
      <div class="score-bar-label">${s.label}</div>
      <div class="score-bar-track"><div class="score-bar-fill" style="width:${val}%;background:linear-gradient(90deg,${color},var(--accent))"></div></div>
      <div class="score-bar-val">${val}</div>
    </div>`;
  });
  el.innerHTML = html;
}

