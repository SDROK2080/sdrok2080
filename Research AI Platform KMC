          messages: [{ role: 'user', content: agent.task }]
        })
      });
      
      const data = await res.json();
      const text = data.content?.map(b => b.text || '').join('') || 'Agent output unavailable.';
      
      fullOutput += `\n\n═══ ${agent.name.toUpperCase()} ═══\n${text}`;
      outputEl.innerHTML = '<div class="ai-content">' + formatMarkdown(fullOutput) + '</div>';
      setAgentStatus(agent.id, 'done');
      await delay(400);
      
    } catch (err) {
      fullOutput += `\n\n═══ ${agent.name.toUpperCase()} ═══\n[Agent encountered an error: ${err.message}]`;
      outputEl.innerHTML = '<div class="ai-content">' + formatMarkdown(fullOutput) + '</div>';
      setAgentStatus(agent.id, 'error');
    }
  }
  
  agentRunning = false;
  showToast('🧠 Research team completed their tasks');
}

function stopAgentTeam() {
  agentRunning = false;
  showToast('⏹ Agent team stopped');
  ['director','literature','methodology','statistician','ml','writer','citation','reviewer','scopus'].forEach(id => setAgentStatus(id, 'standby'));
}

function setAgentStatus(id, status) {
  const card = document.getElementById('agent-' + id);
  const tag = document.getElementById('agent-' + id + '-status');
  if (!card || !tag) return;
  card.className = 'agent-card' + (status === 'running' ? ' running' : '');
  const labels = { standby: ['tag-accent','Standby'], running: ['tag-teal','Running...'], done: ['tag-teal','✓ Done'], error: ['tag-rose','Error'] };
  const [cls, text] = labels[status] || labels.standby;
  tag.className = 'tag ' + cls;
  tag.textContent = text;
}

/* ═══════════════════════════════════════════════════════
   KNOWLEDGE GRAPH
═══════════════════════════════════════════════════════ */
let kgNodes = [];
let kgEdges = [];
let kgDragging = null;
let kgAnimFrame = null;

function initKnowledgeGraph() {
  const canvas = document.getElementById('kgCanvas');
  if (!canvas || canvas._initialized) return;
  canvas._initialized = true;
  
  canvas.addEventListener('mousedown', kgMouseDown);
  canvas.addEventListener('mousemove', kgMouseMove);
  canvas.addEventListener('mouseup', () => kgDragging = null);
  canvas.addEventListener('touchstart', e => { e.preventDefault(); kgMouseDown(e.touches[0]); }, { passive: false });
  canvas.addEventListener('touchmove', e => { e.preventDefault(); kgMouseMove(e.touches[0]); }, { passive: false });
  canvas.addEventListener('touchend', () => kgDragging = null);
  
  generateKG();
}

function generateKG() {
  const W = document.getElementById('kgCanvas').offsetWidth;
  const H = 420;
  const cx = W / 2, cy = H / 2;
  
  const topics = [
    { label: 'Mathematics Education', type: 'topic', x: cx, y: cy },
    { label: 'Critical Thinking', type: 'topic', x: cx - 160, y: cy - 80 },
    { label: 'AI in Education', type: 'topic', x: cx + 160, y: cy - 80 },
    { label: 'Nepal Context', type: 'keyword', x: cx - 200, y: cy + 80 },
    { label: 'Quantitative Methods', type: 'keyword', x: cx + 200, y: cy + 80 },
    { label: 'CAAP Instrument', type: 'paper', x: cx - 120, y: cy + 160 },
    { label: 'Bandura (1997)', type: 'author', x: cx + 80, y: cy + 160 },
    { label: 'Facione (1990)', type: 'author', x: cx - 280, y: cy - 20 },
    { label: 'KMC Students N=268', type: 'paper', x: cx + 240, y: cy - 20 },
    { label: 'Self-Efficacy', type: 'keyword', x: cx + 100, y: cy - 160 },
    { label: 'Achievement', type: 'keyword', x: cx - 80, y: cy - 160 },
  ];
  
  kgNodes = topics.map((n, i) => ({ ...n, id: i, vx: 0, vy: 0, r: n.type === 'topic' ? 28 : 20 }));
  
  kgEdges = [
    [0,1],[0,2],[0,4],[1,5],[1,7],[1,10],[2,6],[2,8],[0,3],[2,9],[9,6],[10,0]
  ];
  
  updateKGStats();
  drawKG();
}

function resetKG() { kgNodes = []; kgEdges = []; drawKG(); }

function addKGNode() {
  const name = document.getElementById('kg-node-name').value.trim();
  const type = document.getElementById('kg-node-type').value.toLowerCase();
  if (!name) return;
  const W = document.getElementById('kgCanvas').offsetWidth;
  kgNodes.push({
    id: kgNodes.length, label: name, type: type,
    x: Math.random() * (W - 100) + 50, y: Math.random() * 300 + 60,
    r: type === 'topic' ? 28 : 20, vx: 0, vy: 0
  });
  if (kgNodes.length > 1) kgEdges.push([0, kgNodes.length - 1]);
  document.getElementById('kg-node-name').value = '';
  updateKGStats();
  drawKG();
}

function updateKGStats() {
  const el = document.getElementById('kg-stats');
  if (!el) return;
  const types = {};
  kgNodes.forEach(n => types[n.type] = (types[n.type] || 0) + 1);
  el.innerHTML = `<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
    ${Object.entries(types).map(([t,c]) => `<div><span style="color:var(--text-2);text-transform:capitalize">${t}s</span>: <strong>${c}</strong></div>`).join('')}
    <div><span style="color:var(--text-2)">Connections</span>: <strong>${kgEdges.length}</strong></div>
    <div><span style="color:var(--text-2)">Total Nodes</span>: <strong>${kgNodes.length}</strong></div>
  </div>`;
}

function drawKG() {
  const canvas = document.getElementById('kgCanvas');
  if (!canvas) return;
  const W = canvas.offsetWidth;
  const H = 420;
  canvas.width = W;
  canvas.height = H;
  const ctx = canvas.getContext('2d');
  const isDark = document.documentElement.getAttribute('data-theme') !== 'light';
  
  ctx.clearRect(0, 0, W, H);
  
  const TYPE_COLORS = {
    topic: '#6C63FF', paper: '#00D4AA', author: '#FFB347', keyword: '#FF6584'
  };
  
  // Draw edges
  kgEdges.forEach(([a, b]) => {
    const na = kgNodes[a], nb = kgNodes[b];
    if (!na || !nb) return;
    ctx.beginPath();
    ctx.moveTo(na.x, na.y);
    ctx.lineTo(nb.x, nb.y);
    ctx.strokeStyle = isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.1)';
    ctx.lineWidth = 1.5;
    ctx.stroke();
  });
  
  // Draw nodes
  kgNodes.forEach(n => {
    const color = TYPE_COLORS[n.type] || '#6C63FF';
    
    // Glow
    ctx.beginPath();
    ctx.arc(n.x, n.y, n.r + 6, 0, Math.PI * 2);
    ctx.fillStyle = color + '22';
    ctx.fill();
    
    // Node
    ctx.beginPath();
    ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
    ctx.fillStyle = color + '33';
    ctx.fill();
    ctx.strokeStyle = color;
    ctx.lineWidth = 2;
    ctx.stroke();
    
    // Label
    ctx.fillStyle = isDark ? '#F0F2FF' : '#1A1D35';
    ctx.font = `${n.type === 'topic' ? 600 : 400} 11px 'Space Grotesk', sans-serif`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    
    // Wrap long labels
    const words = n.label.split(' ');
    if (words.length <= 2 || n.r >= 28) {
      ctx.fillText(n.label.length > 14 ? n.label.slice(0, 12) + '…' : n.label, n.x, n.y);
    } else {
      ctx.fillText(words.slice(0, 2).join(' '), n.x, n.y - 6);
      ctx.fillText(words.slice(2).join(' '), n.x, n.y + 8);
    }
  });
}

function kgMouseDown(e) {
  const canvas = document.getElementById('kgCanvas');
  const rect = canvas.getBoundingClientRect();
  const mx = (e.clientX || e.pageX) - rect.left;
  const my = (e.clientY || e.pageY) - rect.top;
  kgDragging = kgNodes.find(n => Math.hypot(n.x - mx, n.y - my) < n.r + 8) || null;
}

function kgMouseMove(e) {
  if (!kgDragging) return;
  const canvas = document.getElementById('kgCanvas');
  const rect = canvas.getBoundingClientRect();
  kgDragging.x = (e.clientX || e.pageX) - rect.left;
  kgDragging.y = (e.clientY || e.pageY) - rect.top;
  drawKG();
}

/* ═══════════════════════════════════════════════════════
   SIDEBAR CANVAS ANIMATION
═══════════════════════════════════════════════════════ */
function initSidebarCanvas() {
  const canvas = document.getElementById('sidebarCanvas');
  const W = 260, H = window.innerHeight;
  canvas.width = W; canvas.height = H;
  const ctx = canvas.getContext('2d');
  
  const particles = Array.from({ length: 30 }, () => ({
    x: Math.random() * W, y: Math.random() * H,
    r: Math.random() * 2 + 0.5,
    vx: (Math.random() - 0.5) * 0.3,
    vy: (Math.random() - 0.5) * 0.3
  }));
  
  function draw() {
    ctx.clearRect(0, 0, W, H);
    
    particles.forEach(p => {
      p.x += p.vx; p.y += p.vy;
      if (p.x < 0 || p.x > W) p.vx *= -1;
      if (p.y < 0 || p.y > H) p.vy *= -1;
    });
    
    // Draw connections
    particles.forEach((p, i) => {
      particles.slice(i + 1).forEach(q => {
        const d = Math.hypot(p.x - q.x, p.y - q.y);
        if (d < 80) {
          ctx.beginPath();
          ctx.moveTo(p.x, p.y);
          ctx.lineTo(q.x, q.y);
          ctx.strokeStyle = `rgba(108,99,255,${0.15 * (1 - d / 80)})`;
          ctx.lineWidth = 0.5;
          ctx.stroke();
        }
      });
    });
    
    particles.forEach(p => {
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(108,99,255,0.6)';
      ctx.fill();
    });
    
    requestAnimationFrame(draw);
  }
  draw();
}

